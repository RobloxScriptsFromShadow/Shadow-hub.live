        body.theme-ruby { --accent: #ff4f8b; --accent-glow: rgba(255, 79, 139, 0.3); --bg: #0a0101; }
        body.theme-emerald { --accent: #4ade80; --accent-glow: rgba(74, 222, 128, 0.3); --bg: #010a05; }
        body.theme-ocean { --accent: #3b82f6; --accent-glow: rgba(59, 130, 246, 0.3); --bg: #01050a; }

        @keyframes chroma {
