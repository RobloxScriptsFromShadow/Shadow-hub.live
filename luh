<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ShadowHub | Elite V4</title>
    <link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@500;800&family=Plus+Jakarta+Sans:wght@300;400;600;800&family=JetBrains+Mono&display=swap" rel="stylesheet">
    <style>
        :root {
            --accent: #c084fc;
            --accent-glow: rgba(192, 132, 252, 0.3);
            --bg: #05010a;
            --glass: rgba(15, 10, 25, 0.7);
            --border: rgba(255, 255, 255, 0.08);
            --sidebar-w: 280px;
        }

        * { box-sizing: border-box; outline: none; -webkit-font-smoothing: antialiased; }

        body {
            margin: 0;
            font-family: 'Plus Jakarta Sans', sans-serif;
            background-color: var(--bg);
            color: #fff;
            overflow: hidden;
            background-image: 
                radial-gradient(circle at 15% 15%, rgba(139, 92, 246, 0.08), transparent 35%),
                radial-gradient(circle at 85% 85%, rgba(192, 132, 252, 0.08), transparent 35%);
            display: flex;
        }

        /* --- SIDEBAR --- */
        .sidebar {
            width: var(--sidebar-w);
            height: 100vh;
            background: rgba(10, 5, 20, 0.8);
            backdrop-filter: blur(30px);
            border-right: 1px solid var(--border);
            display: flex;
            flex-direction: column;
            padding: 40px 20px;
            z-index: 1000;
        }

        .side-logo {
            font-family: 'Orbitron';
            font-size: 1.4rem;
            letter-spacing: 6px;
            margin-bottom: 40px;
            text-align: center;
            font-weight: 800;
            color: var(--accent);
            text-shadow: 0 0 20px var(--accent-glow);
        }

        .nav-group { margin-bottom: 30px; }
        .nav-label { font-family: 'Orbitron'; font-size: 9px; opacity: 0.3; letter-spacing: 2px; margin-left: 20px; margin-bottom: 15px; display: block; }

        .nav-item {
            padding: 14px 20px;
            border-radius: 12px;
            margin-bottom: 8px;
            cursor: pointer;
            font-family: 'Orbitron';
            font-size: 10px;
            letter-spacing: 1.5px;
            color: rgba(255,255,255,0.4);
            transition: all 0.3s ease;
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .nav-item:hover { color: #fff; background: rgba(255,255,255,0.03); }
        .nav-item.active {
            background: linear-gradient(90deg, rgba(192, 132, 252, 0.15) 0%, transparent 100%);
            color: var(--accent);
            border-left: 3px solid var(--accent);
        }

        /* --- MAIN CONTENT --- */
        .main-wrapper {
            flex-grow: 1;
            height: 100vh;
            overflow-y: auto;
            position: relative;
        }

        /* --- SEARCH BAR --- */
        .search-container {
            position: sticky;
            top: 0;
            padding: 30px 8% 20px;
            background: linear-gradient(to bottom, var(--bg) 60%, transparent);
            z-index: 100;
        }

        .search-wrapper {
            position: relative;
            max-width: 600px;
        }

        #searchInput {
            width: 100%;
            background: rgba(255,255,255,0.03);
            border: 1px solid var(--border);
            padding: 18px 25px 18px 55px;
            border-radius: 20px;
            color: #fff;
            font-family: 'Plus Jakarta Sans';
            font-size: 14px;
            transition: 0.3s;
            backdrop-filter: blur(10px);
        }

        #searchInput:focus {
            border-color: var(--accent);
            background: rgba(255,255,255,0.05);
            box-shadow: 0 0 30px rgba(192, 132, 252, 0.1);
        }

        .search-icon {
            position: absolute;
            left: 22px;
            top: 50%;
            transform: translateY(-50%);
            opacity: 0.3;
            font-size: 18px;
        }

        /* --- SECTIONS --- */
        .content-section { display: none; padding: 20px 8% 100px; }
        .content-section.active { display: block; }

        .grid { 
            display: grid; 
            grid-template-columns: repeat(auto-fill, minmax(320px, 1fr)); 
            gap: 25px; 
        }

        /* --- CARDS --- */
        .card {
            background: var(--glass); border: 1px solid var(--border); border-radius: 28px;
            padding: 35px; backdrop-filter: blur(12px); position: relative;
            transform: translateY(20px); opacity: 0;
            transition: all 0.5s cubic-bezier(0.16, 1, 0.3, 1);
        }
        .card.visible { transform: translateY(0); opacity: 1; }
        .card:hover { border-color: var(--accent); transform: translateY(-5px); }

        .status { font-size: 9px; color: #4ade80; font-weight: 800; letter-spacing: 1.5px; margin-bottom: 12px; display: block; }
        .card h3 { font-family: 'Orbitron'; font-size: 1.2rem; margin: 0 0 10px; font-weight: 800; }
        .features { font-size: 13px; color: rgba(255,255,255,0.4); line-height: 1.5; margin-bottom: 20px; }

        .btn {
            width: 100%; padding: 16px; border-radius: 14px; border: none;
            background: #fff; color: #000; font-weight: 800; font-family: 'Orbitron'; font-size: 9px;
            cursor: pointer; transition: 0.3s;
        }
        .btn:hover { background: var(--accent); color: #fff; box-shadow: 0 10px 25px var(--accent-glow); }

        /* --- PAID TAG --- */
        .paid-badge {
            background: #ff4f8b; color: #fff; font-size: 8px; padding: 4px 10px;
            border-radius: 6px; font-family: 'Orbitron'; position: absolute; top: 35px; right: 35px;
        }

        /* --- CONTACT CARD --- */
        .contact-box {
            max-width: 500px; margin: 50px auto; background: var(--glass);
            border: 1px solid var(--border); border-radius: 30px; padding: 50px; text-align: center;
        }

        /* --- UI HELPERS --- */
        #loader { position: fixed; inset: 0; background: #000; display: flex; justify-content: center; align-items: center; z-index: 10000; transition: 0.8s; }
        .overlay { position: fixed; inset: 0; background: rgba(0,0,0,0.85); backdrop-filter: blur(12px); z-index: 5000; display: none; opacity: 0; transition: 0.4s; }
        .modal { position: fixed; top: 50%; left: 50%; transform: translate(-50%, -45%) scale(0.9); width: 90%; max-width: 500px; background: #0a0a0f; border: 1px solid var(--border); border-radius: 32px; padding: 40px; z-index: 5001; display: none; opacity: 0; transition: 0.4s cubic-bezier(0.16, 1, 0.3, 1); }
        .modal.active { transform: translate(-50%, -50%) scale(1); opacity: 1; }
        #scriptBox { width: 100%; height: 180px; background: #000; border: 1px solid var(--border); border-radius: 18px; color: var(--accent); font-family: 'JetBrains Mono'; font-size: 12px; padding: 20px; margin: 20px 0; resize: none; }
        #toast { position: fixed; bottom: 40px; right: 40px; background: #fff; color: #000; padding: 18px 30px; border-radius: 15px; z-index: 10005; transform: translateX(200%); transition: 0.5s; font-family: 'Orbitron'; font-size: 10px; font-weight: 800; }
        #toast.active { transform: translateX(0); }
    </style>
</head>
<body>

    <div id="loader"><div class="side-logo" style="font-size: 2.5rem;">SHADOW</div></div>
    <div id="toast">SYSTEM NOTIFICATION</div>

    <div class="sidebar">
        <div class="side-logo">SHADOW</div>
        
        <div class="nav-group">
            <span class="nav-label">LIBRARY</span>
            <div class="nav-item active" onclick="switchTab('main-tab', this)">
                <span>📂</span> FREE SCRIPTS
            </div>
            <div class="nav-item" onclick="switchTab('paid-tab', this)">
                <span>💎</span> PAID
            </div>
        </div>

        <div class="nav-group">
            <span class="nav-label">SYSTEM</span>
            <div class="nav-item" onclick="switchTab('contact-tab', this)">
                <span>💬</span> CONTACT
            </div>
        </div>

        <div style="margin-top: auto; font-size: 8px; opacity: 0.2; text-align: center; font-family: Orbitron; letter-spacing: 2px;">BUILD 2026.V4</div>
    </div>

    <div class="main-wrapper">
        
        <div class="search-container">
            <div class="search-wrapper">
                <span class="search-icon">🔍</span>
                <input type="text" id="searchInput" placeholder="Search for scripts..." onkeyup="filterScripts()">
            </div>
        </div>

        <section id="main-tab" class="content-section active">
            <div class="grid" id="freeGrid">
                <div class="card" data-name="bloxy ai chatbot assistant">
                    <span class="status">ONLINE</span>
                    <h3>Bloxy AI Chatbot</h3>
                    <p class="features">Universal AI Assistant • Adaptive Dialogue • Low Latency</p>
                    <button class="btn" onclick="openScript('bloxyai', event)">INITIALIZE</button>
                </div>

                <div class="card" data-name="escape tsunami brainrot">
                    <span class="status">ONLINE</span>
                    <h3>Escape Tsunami</h3>
                    <p class="features">Brainrot Utility • Auto-Filter • Visuals • Event Sniper</p>
                    <button class="btn" onclick="openScript('tsunami', event)">INITIALIZE</button>
                </div>

                <div class="card" data-name="mags utility football fusion">
                    <span class="status">ONLINE</span>
                    <h3>Mags Utility</h3>
                    <p class="features">FF2 • Catch Resize • Vector Pull • ESP Suite</p>
                    <button class="btn" onclick="openScript('mags', event)">INITIALIZE</button>
                </div>

                <div class="card" data-name="battlegrounds tsb strongest">
                    <span class="status">ONLINE</span>
                    <h3>Battlegrounds</h3>
                    <p class="features">TSB • Auto Block • Ping ESP • Kill Counters</p>
                    <button class="btn" onclick="openScript('battlegrounds', event)">INITIALIZE</button>
                </div>

                <div class="card" data-name="infinite yield universal admin">
                    <span class="status">ONLINE</span>
                    <h3>Infinite Yield</h3>
                    <p class="features">Admin Commands • Fly • Noclip • Dark Dex</p>
                    <button class="btn" onclick="openScript('universal', event)">INITIALIZE</button>
                </div>
            </div>
        </section>

        <section id="paid-tab" class="content-section">
            <div class="grid" id="paidGrid">
                <div class="card" data-name="mm2 murder mystery shadow hub">
                    <div class="paid-badge">PREMIUM</div>
                    <span class="status" style="color:#ffb86c">RESTRICTED</span>
                    <h3>MM2 Shadow Hub</h3>
                    <p class="features">Role Detection • Gun Notifier • Silent Aim • ESP</p>
                    <button class="btn" onclick="openScript('mm2', event)">INITIALIZE</button>
                </div>
            </div>
        </section>

        <section id="contact-tab" class="content-section">
            <div class="contact-box">
                <h2 style="font-family: Orbitron;">DEVELOPER CONTACT</h2>
                <p style="opacity: 0.5; font-size: 14px;">For keys, private builds, or business inquiries.</p>
                <div style="font-family: 'JetBrains Mono'; color: var(--accent); font-size: 1.5rem; padding: 20px; background: rgba(0,0,0,0.3); border-radius: 15px; margin: 25px 0; border: 1px dashed var(--accent);">
                    @your_discord_here
                </div>
                <button class="btn" style="width: auto; padding: 15px 40px;" onclick="copyText('@your_discord_here')">COPY TAG</button>
            </div>
        </section>

    </div>

    <div class="overlay" id="overlay" onclick="closeModals()"></div>

    <div class="modal" id="passModal" onclick="event.stopPropagation()">
        <h2 style="font-family: Orbitron; text-align: center; margin:0;">AUTHORIZATION</h2>
        <p style="text-align: center; font-size: 11px; opacity: 0.5; margin-bottom: 20px;">KEY REQUIRED FOR PREMIUM ACCESS</p>
        <input type="password" id="keyInput" placeholder="ENTER KEY" style="width:100%; padding:20px; background:#000; border:1px solid var(--border); border-radius:18px; color:#fff; text-align:center; font-family: 'JetBrains Mono';">
        <button class="btn" style="margin-top:20px" onclick="verifyKey()">VERIFY ACCESS</button>
    </div>

    <div class="modal" id="scriptModal" onclick="event.stopPropagation()">
        <h2 style="font-family: Orbitron; color:var(--accent); margin:0;">SOURCE</h2>
        <textarea id="scriptBox" readonly></textarea>
        <button class="btn" onclick="copyScript()">COPY SOURCE</button>
        <button class="btn" style="background:transparent; color:#fff; border:1px solid var(--border); margin-top:10px;" onclick="closeModals()">CLOSE</button>
    </div>

<script>
    const MM2_HASH = "9871b54e90be561200f8b18a744469dd551d03d572683760fb91dd85595fca47";
    const SCRIPTS = {
        mm2: 'loadstring(game:HttpGet("https://pastebin.com/raw/ha5Da5WE"))()',
        tsunami: 'loadstring(game:HttpGet("https://api.luarmor.net/files/v4/loaders/8df8114bc794c926c3a435fc00ca3106.lua"))()',
        mags: 'loadstring(game:HttpGet("https://cdn.snc.dev/69a3119532794750001823ca/mn8zhw8gldl"))()',
        battlegrounds: 'loadstring(game:HttpGet("https://raw.githubusercontent.com/hellattexyss/waspire/refs/heads/main/waspirescripts.lua"))()',
        universal: 'loadstring(game:HttpGet("https://rawscripts.net/raw/Universal-Script-Infinite-Yield-43437"))()',
        bloxyai: 'loadstring(game:HttpGet("https://raw.githubusercontent.com/UltraFEmotes/BloxyAI/refs/heads/main/main.lua"))()'
    };

    // 1. IMPROVED FILTER
    function filterScripts() {
        let input = document.getElementById('searchInput').value.toLowerCase();
        let cards = document.querySelectorAll('.card');
        cards.forEach(card => {
            let name = card.getAttribute('data-name').toLowerCase();
            card.style.display = name.includes(input) ? "block" : "none";
        });
    }

    // 2. TAB SWITCHING
    function switchTab(tabId, el) {
        document.querySelectorAll('.content-section').forEach(s => s.classList.remove('active'));
        document.querySelectorAll('.nav-item').forEach(n => n.classList.remove('active'));
        document.getElementById(tabId).classList.add('active');
        el.classList.add('active');
    }

    // 3. SECURE OPENING (The Bug Fix)
    function openScript(id, event) {
        if (event) {
            event.preventDefault();
            event.stopPropagation();
        }
        
        // Use a slight timeout to prevent event bubbling from closing it instantly
        setTimeout(() => {
            if(id === 'mm2') { 
                toggleModal('passModal', true); 
            } else { 
                showSource(id); 
            }
        }, 10);
    }

    function showSource(id) {
        // Force close password modal if it's open
        document.getElementById('passModal').style.display = 'none';
        document.getElementById('passModal').classList.remove('active');
        
        document.getElementById('scriptBox').value = SCRIPTS[id];
        toggleModal('scriptModal', true);
    }

    function toggleModal(id, state) {
        const overlay = document.getElementById('overlay');
        const modal = document.getElementById(id);
        
        if(state) {
            overlay.style.display = 'block';
            modal.style.display = 'block';
            // Reflow
            void modal.offsetWidth; 
            overlay.style.opacity = '1'; 
            modal.classList.add('active'); 
        }
    }

    function closeModals() {
        const overlay = document.getElementById('overlay');
        const modals = document.querySelectorAll('.modal');
        
        modals.forEach(m => m.classList.remove('active'));
        overlay.style.opacity = '0';
        
        setTimeout(() => {
            modals.forEach(m => m.style.display = 'none');
            overlay.style.display = 'none';
        }, 300);
    }

    // 4. UTILITIES
    async function verifyKey() {
        const val = document.getElementById('keyInput').value;
        const buf = new TextEncoder().encode(val);
        const hashBuffer = await crypto.subtle.digest('SHA-256', buf);
        const hash = Array.from(new Uint8Array(hashBuffer)).map(b => b.toString(16).padStart(2, '0')).join('');
        if(hash === MM2_HASH) { 
            showSource('mm2'); 
        } else { 
            showToast("INVALID KEY"); 
        }
    }

    function copyScript() {
        const box = document.getElementById('scriptBox');
        box.select();
        navigator.clipboard.writeText(box.value);
        showToast("COPIED TO CLIPBOARD");
    }

    function copyText(txt) {
        navigator.clipboard.writeText(txt);
        showToast("DISCORD COPIED");
    }

    function showToast(msg) {
        const t = document.getElementById('toast');
        t.innerText = msg;
        t.classList.add('active');
        setTimeout(() => t.classList.remove('active'), 2500);
    }

    window.onload = () => {
        setTimeout(() => {
            document.getElementById('loader').style.opacity = '0';
            setTimeout(() => document.getElementById('loader').style.display = 'none', 800);
            document.querySelectorAll('.card').forEach((c, i) => {
                setTimeout(() => c.classList.add('visible'), i * 80);
            });
        }, 1000);
    };
</script>
</body>
</html>
