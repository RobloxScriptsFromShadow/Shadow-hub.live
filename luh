        .nav-label { font-family: 'Orbitron'; font-size: 9px; opacity: 0.3; letter-spacing: 2px; margin-left: 20px; margin-bottom: 15px; display: block; }

        .nav-item {
            padding: 14px 20px;
            border-radius: 12px;
            margin-bottom: 8px;
            cursor: pointer;
            font-family: 'Orbitron';
            font-size: 10px;
            letter-spacing: 1.5px;
            color: rgba(255,255,255,0.4);
            transition: 0.3s;
            display: flex;
            align-items: center;
            justify-content: space-between;
        }

        .nav-item:hover { color: #fff; background: rgba(255,255,255,0.03); }
        .nav-item.active {
            background: linear-gradient(90deg, var(--accent-glow) 0%, transparent 100%);
            color: var(--accent);
            border-left: 3px solid var(--accent);
        }

        .count-badge {
            font-size: 8px;
            background: rgba(255,255,255,0.1);
            padding: 2px 6px;
            border-radius: 4px;
        }

        .main-wrapper {
            flex-grow: 1;
            height: 100vh;
            overflow-y: auto;
            position: relative;
            scroll-behavior: smooth;
        }

        .header-container {
            position: sticky;
            top: 0;
            padding: 30px 8% 20px;
            background: linear-gradient(to bottom, var(--bg) 80%, transparent);
            z-index: 100;
