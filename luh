            33% { --accent: #4ade80; --accent-glow: rgba(74, 222, 128, 0.3); }
            66% { --accent: #3b82f6; --accent-glow: rgba(59, 130, 246, 0.3); }
            100% { --accent: #ff4f8b; --accent-glow: rgba(255, 79, 139, 0.3); }
