            background: rgba(255,255,255,0.03);
            border: 1px solid var(--border);
            padding: 18px 25px 18px 55px;
            border-radius: 20px;
            color: #fff;
            font-family: 'Plus Jakarta Sans';
            font-size: 14px;
            transition: 0.3s;
            backdrop-filter: blur(var(--blur-amount));
