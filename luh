        .search-icon {
            position: absolute;
            left: 22px;
            top: 50%;
            transform: translateY(-50%);
            opacity: 0.3;
            font-family: 'JetBrains Mono';
            font-size: 14px;
        }

        .content-section { display: none; padding: 20px 8% 100px; }
