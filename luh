        .btn:hover { background: var(--accent); color: #fff; box-shadow: 0 10px 25px var(--accent-glow); }

        .settings-container { max-width: 800px; margin: 0 auto; }
        .setting-row {
            display: flex; align-items: center; justify-content: space-between;
            padding: 25px; background: var(--glass); border: 1px solid var(--border);
            border-radius: 20px; margin-bottom: 15px;
        }

        .theme-grid { display: flex; gap: 15px; }
        .theme-dot { width: 35px; height: 35px; border-radius: 50%; cursor: pointer; border: 3px solid transparent; transition: 0.2s; }
        .theme-dot.active { border-color: #fff; transform: scale(1.1); }

        input[type="range"] { accent-color: var(--accent); width: 140px; }
        input[type="checkbox"] { width: 18px; height: 18px; accent-color: var(--accent); cursor: pointer; }

        #loader { position: fixed; inset: 0; background: #000; display: flex; flex-direction: column; justify-content: center; align-items: center; z-index: 10000; transition: 0.8s; }
        .load-bar { width: 200px; height: 2px; background: rgba(255,255,255,0.1); margin-top: 20px; position: relative; overflow: hidden; }
        .load-bar::after { content: ''; position: absolute; left: 0; top: 0; height: 100%; width: 50%; background: var(--accent); animation: loading 1.5s infinite; }
        @keyframes loading { 0% { left: -50%; } 100% { left: 100%; } }

        .overlay { position: fixed; inset: 0; background: rgba(0,0,0,0.85); backdrop-filter: blur(12px); z-index: 5000; display: none; opacity: 0; transition: 0.4s; }
        .modal { position: fixed; top: 50%; left: 50%; transform: translate(-50%, -45%) scale(0.95); width: 90%; max-width: 500px; background: #0a0a0f; border: 1px solid var(--border); border-radius: 32px; padding: 40px; z-index: 5001; display: none; opacity: 0; transition: 0.4s; }
